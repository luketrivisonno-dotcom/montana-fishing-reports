{
  "name": "montana-fishing-reports",
  "version": "2.3.0",
  "description": "Montana Fishing Reports API - Real-time fishing reports, river conditions, and weather",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "scrape": "node -e \"require('./scrapers').runAllScrapers()\"",
    "cleanup": "curl -X POST http://localhost:8080/api/cleanup"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [
    "fishing",
    "montana",
    "fly-fishing",
    "river-conditions",
    "weather",
    "usgs"
  ],
  "author": "Montana Fishing Reports",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "supertest": "^6.3.3"
  }
}
