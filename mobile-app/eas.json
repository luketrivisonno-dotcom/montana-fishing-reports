{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "../path/to/service-account-key.json",
        "track": "production"
      },
      "ios": {
        "ascAppId": "1234567890",
        "ascApiKeyPath": "../path/to/AuthKey.p8",
        "ascApiKeyIssuerId": "your-issuer-id",
        "ascApiKeyId": "your-key-id"
      }
    }
  }
}
