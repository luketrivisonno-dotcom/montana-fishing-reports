{
  "expo": {
    "name": "Montana Fishing Reports",
    "slug": "montana-fishing-reports",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a5f7a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.montanafishing.reports",
      "buildNumber": "2.0.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Montana Fishing Reports uses your location to show nearby rivers and access points.",
        "NSLocationAlwaysUsageDescription": "Montana Fishing Reports uses your location to provide notifications about nearby fishing conditions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a5f7a"
      },
      "package": "com.montanafishing.reports",
      "versionCode": 20,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Montana Fishing Reports to use your location to find nearby rivers and access points."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1a5f7a"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },
    "owner": "montana-fishing-reports"
  }
}
