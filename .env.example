# ============================================
# Montana Fishing Reports - Environment Config
# ============================================

# Database Configuration
# ----------------------
# For Railway: This is auto-populated
# For local development: Use your PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/fishing_reports

# Server Configuration
# --------------------
PORT=8080
NODE_ENV=development

# Security
# --------
# Generate a strong random string for admin access
ADMIN_KEY=your_super_secret_admin_key_here

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# Rate Limiting (in milliseconds)
# -------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_MAX=30
SCRAPE_RATE_LIMIT_MAX=5

# Payment Configuration (Stripe)
# ------------------------------
# Uncomment and fill in when ready to implement payments
# STRIPE_SECRET_KEY=sk_test_your_key_here
# STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# STRIPE_PRICE_MONTHLY=price_monthly_plan_id
# STRIPE_PRICE_YEARLY=price_yearly_plan_id

# External API Keys
# -----------------
# No API keys required for Open-Meteo (weather) or USGS (water data)
# These are free public APIs

# Feature Flags
# -------------
ENABLE_PREMIUM_FEATURES=true
ENABLE_ANALYTICS=true
ENABLE_SCRAPING=true

# Logging
# -------
LOG_LEVEL=info
# Options: debug, info, warn, error
